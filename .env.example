# Backend API URL
VITE_API_URL=http://localhost:3000

# Set to "true" to enable MSW API mocking in the browser (used with pnpm dev:mock)
VITE_MOCK_API=false

# Set to "true" to bypass login + RBAC locally (all routes/actions enabled)
VITE_AUTH_DISABLED=false

# Set to "true" to enable the dev role switcher dropdown in the header
VITE_DEV_ROLE_SWITCHER=false
